        // Handle Privacy Status Checks
        const isPrivate = p.is_profile_private === true || p.is_profile_public === false;
        const profilePrivacyBadge = document.getElementById('profile-p-privacy-badge');
        const privateLockMessage = document.getElementById('profile-private-lock-message');
        const profilePostsSection = document.getElementById('profile-posts-section');
        const profileBioBlock = document.getElementById('profile-p-bio');

        if (isPrivate) {
          profilePrivacyBadge.innerHTML = `<span class="text-[9px] uppercase font-bold text-amber-500 bg-amber-500/10 px-2.5 py-1 rounded-full border border-amber-500/20"><i class="fa-solid fa-lock text-[8px] mr-1"></i>Private Profile</span>`;
        } else {
          profilePrivacyBadge.innerHTML = `<span class="text-[9px] uppercase font-bold text-emerald-400 bg-emerald-500/10 px-2.5 py-1 rounded-full border border-emerald-500/20">Public Profile</span>`;
        }

        // Check relationship (is following, pending, or self)
        const isMe = uid === auth.currentUser?.uid;
        const following = myFollowingSet.has(uid);
        const requested = myFollowRequestsPendingSet.has(uid);

        const followBtn = document.getElementById('btn-profile-follow');
        const reqBtn = document.getElementById('btn-request-follow');

        if (isMe) {
          followBtn.classList.add('hidden');
          privateLockMessage.classList.add('hidden');
          profilePostsSection.classList.remove('hidden');
          profileBioBlock.textContent = p.profile_bio || 'No athlete resume or performance stats updated yet.';
        } else {
          followBtn.classList.remove('hidden');
          
          if (following) {
            followBtn.innerHTML = `<i class="fa-solid fa-user-check"></i> <span>Following</span>`;
            followBtn.className = "bg-emerald-500 hover:bg-emerald-600 text-white font-bold text-xs px-4 py-1.5 rounded-full shadow-lg transition-all flex items-center gap-1.5";
            
            privateLockMessage.classList.add('hidden');
            profilePostsSection.classList.remove('hidden');
            profileBioBlock.textContent = p.profile_bio || 'No athlete resume or performance stats updated yet.';
          } else if (requested) {
            followBtn.innerHTML = `<i class="fa-solid fa-hourglass-half"></i> <span>Requested</span>`;
            followBtn.className = "bg-zinc-700 text-gray-300 font-bold text-xs px-4 py-1.5 rounded-full shadow-lg transition-all flex items-center gap-1.5 cursor-not-allowed";
            
            if (isPrivate) {
              privateLockMessage.classList.remove('hidden');
              reqBtn.textContent = "Request Pending Approval";
              reqBtn.disabled = true;
              profilePostsSection.classList.add('hidden');
              profileBioBlock.textContent = "✨ Content Locked ✨";
            } else {
              privateLockMessage.classList.add('hidden');
              profilePostsSection.classList.remove('hidden');
              profileBioBlock.textContent = p.profile_bio || 'No athlete resume or performance stats updated yet.';
            }
          } else {
            // Normal state
            followBtn.innerHTML = `<i class="fa-solid fa-user-plus"></i> <span>Follow Athlete</span>`;
            followBtn.className = "bg-combine-gold hover:opacity-90 text-black font-bold text-xs px-4 py-1.5 rounded-full shadow-lg transition-all flex items-center gap-1.5";
            
            if (isPrivate) {
              privateLockMessage.classList.remove('hidden');
              reqBtn.textContent = "Transmit Follow Request";
              reqBtn.disabled = false;
              profilePostsSection.classList.add('hidden');
              profileBioBlock.textContent = "✨ Content Locked ✨";
            } else {
              privateLockMessage.classList.add('hidden');
              profilePostsSection.classList.remove('hidden');
              profileBioBlock.textContent = p.profile_bio || 'No athlete resume or performance stats updated yet.';
            }
          }
        }

        // Count followers
        const count = await getFollowersCount(uid);
        document.getElementById('profile-p-follower-count').textContent = count;

        // Set status
        const statusBadge = document.getElementById('profile-p-status-badge');
        if (p.is_suspended === true) {
          statusBadge.textContent = "Suspended";
          statusBadge.className = "text-sm font-bold text-rose-500 mt-0.5";
