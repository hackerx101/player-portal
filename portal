    // Profile detail modal activation - switches to Social Media view now
    window.openPlayerProfile = async function(uid) {
      toggleLoader(true);
      try {
        const playerDoc = await getDoc(doc(db, 'artifacts', appId, 'public', 'data', 'profiles', uid));
