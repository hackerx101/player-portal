```html
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>NFSMEC - Middle Elite Combine Sports Portal</title>
  
  <!-- Tailwind CSS -->
  <script src="https://cdn.tailwindcss.com"></script>
  <!-- Font Awesome for Sporty & Modern Icons -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <!-- Google Fonts -->
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;700;800&family=Space+Grotesk:wght@500;700&display=swap" rel="stylesheet">

  <style>
    body {
      font-family: 'Outfit', sans-serif;
      background-color: #0b0c10;
      color: #f5f5f7;
    }
    .font-display {
      font-family: 'Space Grotesk', sans-serif;
    }
    /* Smooth Transitions */
    .fade-in {
      animation: fadeIn 0.3s ease-in-out forwards;
    }
    @keyframes fadeIn {
      from { opacity: 0; transform: translateY(8px); }
      to { opacity: 1; transform: translateY(0); }
    }
    /* Premium Design System */
    .bg-combine-gold {
      background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%);
    }
    .text-combine-gold {
      color: #f59e0b;
    }
    .border-combine-gold {
      border-color: #f59e0b;
    }
    .glass-card {
      background: rgba(22, 22, 26, 0.8);
      backdrop-filter: blur(16px);
      border: 1px solid rgba(255, 255, 255, 0.08);
    }
    /* Hide scrollbars elegantly */
    ::-webkit-scrollbar {
      width: 6px;
      height: 6px;
    }
    ::-webkit-scrollbar-track {
      background: rgba(0,0,0,0.15);
    }
    ::-webkit-scrollbar-thumb {
      background: rgba(245, 158, 11, 0.25);
      border-radius: 999px;
    }
    ::-webkit-scrollbar-thumb:hover {
      background: rgba(245, 158, 11, 0.6);
    }
  </style>
</head>
<body class="min-h-screen flex flex-col justify-between overflow-x-hidden">

  <!-- Notification Toast Container -->
  <div id="notification-container" class="fixed top-4 right-4 z-50 flex flex-col gap-2 max-w-sm w-full"></div>

  <!-- Loading Screen Overlay -->
  <div id="global-loader" class="fixed inset-0 bg-[#07080c] z-50 flex flex-col items-center justify-center transition-opacity duration-300">
    <div class="relative w-20 h-20">
      <div class="absolute inset-0 rounded-full border-4 border-amber-500/10"></div>
      <div class="absolute inset-0 rounded-full border-4 border-t-amber-500 animate-spin"></div>
    </div>
    <p class="mt-4 text-amber-500 font-display font-bold tracking-widest text-sm uppercase">Synchronizing Athlete Nodes...</p>
  </div>

  <!-- Banned/Suspended Overlay Screen (Stuck screen if set_temp_ban or is_suspended is true) -->
  <div id="view-suspended" class="fixed inset-0 bg-[#0d0202] z-40 flex flex-col justify-between hidden p-6 overflow-y-auto">
    <!-- Header with Logout option -->
    <div class="flex justify-between items-center border-b border-rose-500/10 pb-4">
      <div class="flex items-center gap-2">
        <i class="fa-solid fa-triangle-exclamation text-rose-500 text-xl animate-pulse"></i>
        <h1 class="text-white font-display font-bold uppercase tracking-wider text-sm">Account Suspended</h1>
      </div>
      <!-- Hamburger Option Menu inside suspended screen to let them logout safely -->
      <div class="relative">
        <button onclick="toggleSuspendedMenu()" class="text-gray-400 hover:text-white bg-white/5 px-3 py-1.5 rounded-lg text-xs font-semibold flex items-center gap-2">
          <span>Options</span>
          <i class="fa-solid fa-bars"></i>
        </button>
        <div id="suspended-dropdown" class="absolute right-0 mt-2 w-48 bg-zinc-950 border border-rose-500/20 rounded-xl shadow-2xl hidden py-1">
          <button onclick="triggerSuspendedLogout()" class="w-full text-left px-4 py-2 text-xs text-rose-400 hover:bg-rose-500/10 font-bold flex items-center gap-2">
            <i class="fa-solid fa-sign-out-alt"></i> Sign Out from Locker
          </button>
        </div>
      </div>
    </div>

    <!-- Suspension Content & AI Appeal -->
    <div class="max-w-md mx-auto my-auto w-full space-y-6 py-8">
      <div class="text-center">
        <div class="w-16 h-16 bg-rose-500/10 border border-rose-500/30 text-rose-500 rounded-full flex items-center justify-center mx-auto mb-4">
          <i class="fa-solid fa-ban text-2xl"></i>
        </div>
        <h2 class="text-2xl font-display font-extrabold text-white">Combine Status: Suspended</h2>
        <p class="text-rose-400 text-xs mt-1 font-mono uppercase tracking-wider" id="suspension-status-label">TEMP_BAN ACTIVE</p>
      </div>

      <div class="bg-rose-950/20 border border-rose-500/20 rounded-2xl p-5 space-y-3">
        <h3 class="text-xs font-bold text-white uppercase tracking-wider border-b border-rose-500/10 pb-2">Violation File Details</h3>
        <div>
          <span class="text-[9px] uppercase text-gray-500 block">Restricted Athlete Username</span>
          <input type="text" id="suspended-username" readonly class="w-full bg-black/40 border border-white/5 rounded-lg py-1.5 px-3 text-gray-400 text-xs font-mono focus:outline-none" value="@username">
        </div>
        <div>
          <span class="text-[9px] uppercase text-gray-500 block">Ban Duration Remaining</span>
          <p class="text-xs text-white font-bold" id="ban-time-remaining">Pending system refresh...</p>
        </div>
        <div>
          <span class="text-[9px] uppercase text-gray-500 block">Primary Reason / AI Assessment</span>
          <p id="suspension-reason" class="text-xs text-rose-300 font-semibold bg-rose-950/40 p-2.5 rounded-lg border border-rose-500/10 mt-1">
            Violent Threat / Threat of physical harm reported and confirmed by automated filters.
          </p>
        </div>
      </div>

      <!-- Appeal Form -->
      <form id="appeal-form" class="bg-zinc-900 border border-white/5 rounded-2xl p-5 space-y-3">
        <h3 class="text-xs font-bold text-white uppercase tracking-wider">Submit Appeal to AI Arbiter</h3>
        <p class="text-[10px] text-gray-400">Our automated combine supervisor processes appeals instantly based on remorse, threat seriousness, and previous history.</p>
        <div>
          <label class="block text-[9px] uppercase text-gray-400 mb-1">Explain your side of the situation:</label>
          <textarea id="appeal-text" required rows="3" placeholder="Please clarify why your account should be restored..." 
            class="w-full bg-black border border-white/10 rounded-xl p-3 text-white text-xs focus:outline-none focus:border-rose-500 transition-all resize-none"></textarea>
        </div>
        <button type="submit" class="w-full bg-rose-500 hover:bg-rose-600 text-white font-display font-bold py-2.5 rounded-xl text-xs transition-all flex items-center justify-center gap-2">
          <span>Transmit Appeal</span>
          <i class="fa-solid fa-paper-plane"></i>
        </button>
      </form>
    </div>

    <div class="text-center py-4 border-t border-rose-500/10">
      <p class="text-[10px] text-gray-500">NFSMEC Elite Committee Automated Safety Protocols • Ver 4.0</p>
    </div>
  </div>

  <!-- Header Section -->
  <header class="w-full bg-black/85 border-b border-white/5 py-4 px-6 flex items-center justify-between sticky top-0 z-30 backdrop-blur-md">
    <div class="flex items-center gap-3">
      <div class="w-10 h-10 bg-combine-gold rounded-xl flex items-center justify-center shadow-lg shadow-amber-500/20">
        <i class="fa-solid fa-trophy text-black text-xl"></i>
      </div>
      <div>
        <h1 class="font-display font-bold text-lg tracking-wider text-white uppercase leading-none">NFSMEC</h1>
        <p class="text-[10px] text-amber-500 font-semibold tracking-widest uppercase mt-1">Combine Sports Portal</p>
      </div>
    </div>
    <div id="user-badge" class="hidden flex items-center gap-3 bg-white/5 py-1.5 px-3 rounded-full border border-white/10">
      <div class="w-2 h-2 rounded-full bg-emerald-500 animate-pulse"></div>
      <span id="badge-name" class="text-xs font-semibold text-gray-300">Athlete</span>
    </div>
  </header>

  <!-- Main Container -->
  <main class="flex-grow flex flex-col w-full max-w-5xl mx-auto px-4 py-6 mb-24">

    <!-- ============================================== -->
    <!-- SIGNUP PAGE                                    -->
    <!-- ============================================== -->
    <div id="view-signup" class="view-panel w-full max-w-lg mx-auto glass-card rounded-2xl p-6 md:p-8 shadow-2xl fade-in hidden">
      <div class="text-center mb-6">
        <span class="text-xs font-bold uppercase tracking-widest text-amber-500 bg-amber-500/10 px-3 py-1 rounded-full">Athlete Registration</span>
        <h2 class="text-2xl font-display font-bold text-white mt-3">Join Combine Roster</h2>
        <p class="text-gray-400 text-sm mt-1">Create your professional profile and receive an automated 10-digit ID.</p>
      </div>

      <form id="signup-form" class="space-y-4">
        <div>
          <label class="block text-xs font-semibold uppercase text-gray-400 mb-1">Full Player Name</label>
          <div class="relative">
            <i class="fa-solid fa-user absolute left-3 top-3.5 text-gray-500 text-sm"></i>
            <input type="text" id="signup-fullname" required placeholder="e.g. Jaxson Miller" 
              class="w-full bg-black/40 border border-white/10 rounded-xl py-3 pl-10 pr-4 text-white text-sm focus:outline-none focus:border-amber-500 transition-all">
          </div>
        </div>

        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="block text-xs font-semibold uppercase text-gray-400 mb-1">Username</label>
            <div class="relative">
              <i class="fa-solid fa-at absolute left-3 top-3.5 text-gray-500 text-sm"></i>
              <input type="text" id="signup-username" required placeholder="jaxson7" 
                class="w-full bg-black/40 border border-white/10 rounded-xl py-3 pl-10 pr-4 text-white text-sm focus:outline-none focus:border-amber-500 transition-all">
            </div>
          </div>
          <div>
            <label class="block text-xs font-semibold uppercase text-gray-400 mb-1">Date of Birth</label>
            <input type="date" id="signup-dob" required 
              class="w-full bg-black/40 border border-white/10 rounded-xl py-3 px-4 text-white text-sm focus:outline-none focus:border-amber-500 transition-all">
          </div>
        </div>

        <div>
          <label class="block text-xs font-semibold uppercase text-gray-400 mb-1">Email Address</label>
          <div class="relative">
            <i class="fa-solid fa-envelope absolute left-3 top-3.5 text-gray-500 text-sm"></i>
            <input type="email" id="signup-email" required placeholder="athlete@combine.com" 
              class="w-full bg-black/40 border border-white/10 rounded-xl py-3 pl-10 pr-4 text-white text-sm focus:outline-none focus:border-amber-500 transition-all">
          </div>
        </div>

        <div>
          <label class="block text-xs font-semibold uppercase text-gray-400 mb-1">Set Account Password</label>
          <div class="relative">
            <i class="fa-solid fa-lock absolute left-3 top-3.5 text-gray-500 text-sm"></i>
            <input type="password" id="signup-password" required placeholder="••••••••" 
              class="w-full bg-black/40 border border-white/10 rounded-xl py-3 pl-10 pr-4 text-white text-sm focus:outline-none focus:border-amber-500 transition-all">
          </div>
        </div>

        <div>
          <label class="block text-xs font-semibold uppercase text-gray-400 mb-1">Player Bio / Key Stats</label>
          <textarea id="signup-bio" rows="2" placeholder="Position, high school class, outstanding attributes..." 
            class="w-full bg-black/40 border border-white/10 rounded-xl p-3 text-white text-sm focus:outline-none focus:border-amber-500 transition-all resize-none"></textarea>
        </div>

        <button type="submit" class="w-full bg-combine-gold text-black font-display font-bold py-3.5 rounded-xl hover:opacity-95 active:scale-[0.99] transition-all flex items-center justify-center gap-2">
          <span>Create Profile & Generate ID</span>
          <i class="fa-solid fa-arrow-right"></i>
        </button>
      </form>

      <div class="mt-6 text-center border-t border-white/5 pt-4">
        <p class="text-sm text-gray-400">Already registered?</p>
        <button onclick="switchView('view-login')" class="mt-1 text-sm text-amber-500 font-semibold hover:underline">
          Access Portal with Registration ID <i class="fa-solid fa-angle-right text-xs"></i>
        </button>
      </div>
    </div>


    <!-- ============================================== -->
    <!-- LOGIN PAGE                                     -->
    <!-- ============================================== -->
    <div id="view-login" class="view-panel w-full max-w-lg mx-auto glass-card rounded-2xl p-6 md:p-8 shadow-2xl fade-in hidden">
      <div class="text-center mb-6">
        <span class="text-xs font-bold uppercase tracking-widest text-amber-500 bg-amber-500/10 px-3 py-1 rounded-full">Combine Locker Entry</span>
        <h2 class="text-2xl font-display font-bold text-white mt-3">Athlete Credentials</h2>
        <p class="text-gray-400 text-sm mt-1">Authenticate to access combine rankings, global chat, and profile editing.</p>
      </div>

      <form id="login-form" class="space-y-4">
        <div>
          <label class="block text-xs font-semibold uppercase text-gray-400 mb-1">10-Digit Registration Number</label>
          <div class="relative">
            <i class="fa-solid fa-id-card absolute left-3 top-3.5 text-gray-500 text-sm"></i>
            <input type="text" id="login-reg-num" required placeholder="e.g. 1009-48293" 
              class="w-full bg-black/40 border border-white/10 rounded-xl py-3 pl-10 pr-4 text-white text-sm focus:outline-none focus:border-amber-500 transition-all">
          </div>
        </div>

        <div>
          <label class="block text-xs font-semibold uppercase text-gray-400 mb-1">Date of Birth</label>
          <input type="date" id="login-dob" required 
            class="w-full bg-black/40 border border-white/10 rounded-xl py-3 px-4 text-white text-sm focus:outline-none focus:border-amber-500 transition-all">
        </div>

        <div>
          <label class="block text-xs font-semibold uppercase text-gray-400 mb-1">Account Password</label>
          <div class="relative">
            <i class="fa-solid fa-lock absolute left-3 top-3.5 text-gray-500 text-sm"></i>
            <input type="password" id="login-password" required placeholder="••••••••" 
              class="w-full bg-black/40 border border-white/10 rounded-xl py-3 pl-10 pr-4 text-white text-sm focus:outline-none focus:border-amber-500 transition-all">
          </div>
        </div>

        <button type="submit" class="w-full bg-combine-gold text-black font-display font-bold py-3.5 rounded-xl hover:opacity-95 active:scale-[0.99] transition-all flex items-center justify-center gap-2">
          <span>Authorize Entry</span>
          <i class="fa-solid fa-key"></i>
        </button>
      </form>

      <div class="mt-6 text-center border-t border-white/5 pt-4">
        <p class="text-sm text-gray-400">First time participating at NFSMEC?</p>
        <button onclick="switchView('view-signup')" class="mt-1 text-sm text-amber-500 font-semibold hover:underline">
          Enroll Now & Generate Reg ID <i class="fa-solid fa-angle-right text-xs"></i>
        </button>
      </div>
    </div>


    <!-- ============================================== -->
    <!-- HOME DASHBOARD VIEW                            -->
    <!-- ============================================== -->
    <div id="view-home" class="view-panel w-full space-y-6 fade-in hidden">
      <!-- Welcome Header & Recruiter Feedback Widget -->
      <div class="grid grid-cols-1 md:grid-cols-12 gap-6">
        <div class="md:col-span-7 glass-card rounded-2xl p-6 relative overflow-hidden flex flex-col justify-between gap-4">
          <div class="absolute -right-10 -bottom-10 opacity-5 pointer-events-none">
            <i class="fa-solid fa-football text-[120px] text-amber-500"></i>
          </div>
          <div>
            <div class="flex items-center gap-2 text-amber-500 font-bold uppercase tracking-widest text-[10px]">
              <span class="w-2 h-2 rounded-full bg-amber-500 animate-pulse"></span>
              NFSMEC Middle Elite Arena
            </div>
            <h2 class="text-2xl font-display font-extrabold text-white mt-1">
              Welcome, <span id="welcome-player-name" class="text-combine-gold">Athlete</span>!
            </h2>
            <p class="text-xs text-gray-400 mt-1">Your ID: <span id="welcome-player-id" class="font-mono text-white tracking-wider">Loading...</span></p>
          </div>
          <div class="flex items-center gap-2 self-start">
            <div class="text-left">
              <p class="text-[9px] text-gray-400 uppercase tracking-widest">Active Profile Sync</p>
              <p class="text-xs font-semibold text-emerald-400">Live Connection Secured</p>
            </div>
          </div>
        </div>

        <!-- Recruiter Feedback Widget -->
        <div class="md:col-span-5 glass-card rounded-2xl p-6 border-l-4 border-l-amber-500 flex flex-col justify-between">
          <div>
            <div class="flex justify-between items-center">
              <h3 class="text-xs font-display font-bold text-amber-500 uppercase tracking-wider">Recruiter Feedback</h3>
              <span class="text-[9px] uppercase font-mono bg-amber-500/15 text-amber-400 px-2 py-0.5 rounded">Scouting Report</span>
            </div>
            <!-- Live feedback content -->
            <div id="recruiter-feedback-content" class="mt-3 text-xs text-gray-300 italic min-h-[50px] leading-relaxed">
              "Loading certified talent evaluations..."
            </div>
          </div>
          <p class="text-[9px] text-gray-500 mt-2 text-right uppercase tracking-widest">— Verified NFSMEC Recruiter Feed</p>
        </div>
      </div>

      <!-- Main Layout: Grid -->
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-6">
        
        <!-- Left Pane: Combine Players with filter & refresh options (Col-span 5) -->
        <div class="lg:col-span-5 space-y-4">
          <div class="glass-card rounded-2xl p-4 flex flex-col h-[560px]">
            <div class="mb-4 space-y-3">
              <div class="flex justify-between items-center">
                <h3 class="text-sm font-display font-bold text-white uppercase tracking-wider">Combine Roster</h3>
                
                <!-- Filter Dropdown & Refresh tools -->
                <div class="flex items-center gap-2">
                  <select id="roster-limit-filter" class="bg-black/80 border border-white/10 rounded-lg text-[10px] text-amber-500 font-semibold px-2 py-1 focus:outline-none focus:border-amber-500">
                    <option value="3">Show 3</option>
                    <option value="5" selected>Show 5</option>
                    <option value="10">Show 10</option>
                    <option value="20">Show 20</option>
                    <option value="50">Show 50</option>
                    <option value="all">Show All</option>
                  </select>
                  <button id="btn-roster-refresh" onclick="triggerRosterRefresh()" class="w-7 h-7 bg-white/5 hover:bg-white/10 text-white rounded-lg flex items-center justify-center transition-all" title="Shuffle Athletes">
                    <i class="fa-solid fa-arrows-rotate text-xs"></i>
                  </button>
                </div>
              </div>

              <!-- Search Bar -->
              <div class="relative">
                <i class="fa-solid fa-magnifying-glass absolute left-3 top-2.5 text-gray-500 text-xs"></i>
                <input type="text" id="player-search" placeholder="Search athletes, roles, or states..." 
                  class="w-full bg-black/50 border border-white/10 rounded-xl py-2 pl-9 pr-4 text-white text-xs focus:outline-none focus:border-amber-500 transition-all">
              </div>
            </div>

            <!-- Roster List -->
            <div id="player-roster-list" class="flex-grow overflow-y-auto space-y-2 pr-1">
              <!-- Dynamically Populated -->
              <div class="flex items-center justify-center py-12 text-gray-500 text-xs">
                <i class="fa-solid fa-spinner animate-spin mr-2"></i> Syncing Combine roster...
              </div>
            </div>
          </div>
        </div>

        <!-- Right Pane: Live Telemetry Global Chat (Col-span 7) -->
        <div class="lg:col-span-7 space-y-4">
          <div class="glass-card rounded-2xl p-4 flex flex-col h-[560px]">
            <!-- Chat Header & Control Switches -->
            <div class="pb-3 border-b border-white/5 flex flex-col sm:flex-row sm:items-center justify-between gap-2">
              <div>
                <h3 class="text-sm font-display font-bold text-white uppercase tracking-wider">Live Intel Feed</h3>
                <p class="text-[10px] text-gray-400">Tap messages to delete, or report violations to AI Moderation</p>
              </div>
              <!-- Real-time Control Option -->
              <div class="flex items-center gap-3">
                <label class="flex items-center gap-2 cursor-pointer select-none">
                  <div class="relative">
                    <input type="checkbox" id="sync-messages-checkbox" checked class="sr-only peer">
                    <div class="w-8 h-4 bg-gray-600 rounded-full peer peer-focus:ring-0 peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-0.5 after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-3 after:w-3 after:transition-all peer-checked:bg-amber-500"></div>
                  </div>
                  <span class="text-[10px] font-semibold text-gray-300">Sync Live Feed</span>
                </label>
              </div>
            </div>

            <!-- Messages Window -->
            <div id="live-chat-messages" class="flex-grow overflow-y-auto space-y-3 py-4 pr-1">
              <!-- Dynamically Filled -->
              <div class="flex flex-col items-center justify-center py-24 text-gray-500 text-xs">
                <i class="fa-solid fa-comments text-2xl mb-2 text-white/10"></i>
                No messages recorded. Be the first to shoutout!
              </div>
            </div>

            <!-- Anti-Spam Cooldown Indicator -->
            <div id="spam-warning" class="hidden bg-rose-500/10 border border-rose-500/20 rounded-xl p-3 mb-2 flex items-center gap-3">
              <div class="w-8 h-8 rounded-full bg-rose-500/20 flex items-center justify-center text-rose-400 shrink-0">
                <i class="fa-solid fa-triangle-exclamation animate-pulse"></i>
              </div>
              <div class="flex-grow">
                <p class="text-xs font-bold text-rose-400">Transmit Limit Breached!</p>
                <p class="text-[10px] text-gray-400">You've reached maximum send rate. Transmit disabled for 10 minutes.</p>
              </div>
              <div class="text-right shrink-0">
                <span id="countdown-timer" class="text-xs font-mono font-bold text-rose-400">10:00</span>
              </div>
            </div>

            <!-- Message Input Area -->
            <form id="chat-input-form" class="flex gap-2 items-center pt-2 border-t border-white/5">
              <input type="text" id="chat-msg-text" required placeholder="Type combine reports, statistics, or updates..." 
                class="flex-grow bg-black/40 border border-white/10 rounded-xl py-2.5 px-4 text-white text-xs focus:outline-none focus:border-amber-500 transition-all">
              <button type="submit" id="btn-send-msg" class="w-11 h-11 bg-combine-gold text-black rounded-xl hover:opacity-90 active:scale-[0.98] transition-all flex items-center justify-center">
                <i class="fa-solid fa-paper-plane text-sm"></i>
              </button>
            </form>
          </div>
        </div>

      </div>
    </div>


    <!-- ============================================== -->
    <!-- SOCIAL MEDIA ATHLETE PROFILE VIEW              -->
    <!-- ============================================== -->
    <div id="view-profile" class="view-panel w-full max-w-2xl mx-auto space-y-6 fade-in hidden">
      <!-- Back to Dashboard -->
      <button onclick="navigationTo('view-home')" class="text-xs text-amber-500 font-bold hover:underline flex items-center gap-2">
        <i class="fa-solid fa-arrow-left"></i> Return to Main Grid
      </button>

      <!-- Profile Container Card -->
      <div class="glass-card rounded-2xl overflow-hidden shadow-2xl relative">
        <div class="h-32 bg-gradient-to-r from-amber-600 to-amber-900 relative">
          <!-- Follow button / Badge overlay -->
