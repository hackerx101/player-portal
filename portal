          // Free Speech exceptions
          const hasCommonSwear = lowerText.includes("fuck") || lowerText.includes("shit");
          
          // Bullying checks
          const hasBullying = lowerText.includes("mom") || lowerText.includes("trash") || lowerText.includes("loser") || lowerText.includes("suck") || lowerText.includes("bitch") || lowerText.includes("garbage");
          
          // Physical violence
          const hasPhysicalViolence = lowerText.includes("stab") || lowerText.includes("kill") || lowerText.includes("murder") || lowerText.includes("shoot") || lowerText.includes("beat you");

          if (hasPhysicalViolence) {
            aiVerdict = "strike";
            explanation = "AI Detection Confirmed: Serious Physical/Violent Threat. Account flagged with an Orange Triangle Strike.";
          } else if (hasBullying) {
            aiVerdict = "warning";
