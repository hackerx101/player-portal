          statusBadge.textContent = "Active Good Standing";
          statusBadge.className = "text-sm font-bold text-emerald-400 mt-0.5";
        }

        switchView('view-profile');
      } catch (err) {
        showToast(err.message, "error");
      } finally {
        toggleLoader(false);
      }
    };

    // Calculate Followers Count (RULE 2: query basic and filter in JS memory)
    async function getFollowersCount(targetUid) {
      try {
        const followsRef = collection(db, 'artifacts', appId, 'public', 'data', 'follows');
        const snapshot = await new Promise((resolve, reject) => {
          onSnapshot(followsRef, resolve, reject);
        });
        let count = 0;
        snapshot.forEach(doc => {
          if (doc.data().following_uid === targetUid) count++;
        });
        return count;
      } catch (err) {
        return 0;
      }
    }

    // Follow Athlete Logic
    window.triggerProfileFollowAction = async function() {
      if (!auth.currentUser || !targetProfileUser) return;

      // Check double-strike minor violation penalty (follow ban for 1 hour)
      if (followRestrictedUntil && new Date() < followRestrictedUntil) {
        const diff = Math.ceil((followRestrictedUntil - new Date()) / 60000);
        showToast(`Follow action blocked! Follow ban active for another ${diff} minute(s).`, "error");
        return;
      }

      toggleLoader(true);
      const targetUid = targetProfileUser.uid;
      const isPrivate = targetProfileUser.is_profile_private === true || targetProfileUser.is_profile_public === false;

      try {
        if (isPrivate) {
          // Send Follow Request (Target: public/data/follow_requests)
          const reqId = `${auth.currentUser.uid}_${targetUid}`;
          const requestRef = doc(db, 'artifacts', appId, 'public', 'data', 'follow_requests', reqId);
          
          await setDoc(requestRef, {
            request_id: reqId,
            sender_uid: auth.currentUser.uid,
            sender_name: currentUserProfile.player_name || 'Anonymous',
            sender_username: currentUserProfile.player_username || 'unknown',
            receiver_uid: targetUid,
            status: "pending",
            timestamp: new Date().toISOString()
          });

          myFollowRequestsPendingSet.add(targetUid);
          showToast("Follow Request sent successfully! Pending athlete approval.", "success");
        } else {
          // Direct follow (Target: public/data/follows)
          const followId = `${auth.currentUser.uid}_${targetUid}`;
          const followRef = doc(db, 'artifacts', appId, 'public', 'data', 'follows', followId);
          
          await setDoc(followRef, {
            follow_id: followId,
            follower_uid: auth.currentUser.uid,
            following_uid: targetUid,
            timestamp: new Date().toISOString()
          });

          myFollowingSet.add(targetUid);
          showToast(`Successfully following @${targetProfileUser.player_username}!`, "success");
        }

        // Re-open/refresh view state
        openPlayerProfile(targetUid);
      } catch (err) {
        showToast(err.message, "error");
      } finally {
        toggleLoader(false);
      }
    };

    // Settings Profile Visibility switch trigger
    document.getElementById('profile-privacy-toggle').addEventListener('change', async (e) => {
      if (!auth.currentUser) return;
      const isPrivate = e.target.checked;
      toggleLoader(true);
      try {
        const profileRef = doc(db, 'artifacts', appId, 'public', 'data', 'profiles', auth.currentUser.uid);
        await updateDoc(profileRef, {
          is_profile_private: isPrivate,
          is_profile_public: !isPrivate
        });
