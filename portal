                curWarnings++;
              } else if (aiVerdict === "strike") {
                curStrikes.push(`Violent Threat Detected on message: "${reportedMessageText}"`);
              }

              const updatePayload = {
                warning_count: curWarnings,
                orange_strikes: curStrikes
              };

              // Penalty 1: If double-strike (2 Strikes) or double violent threats: set_temp_ban active
              if (curStrikes.length >= 2) {
                updatePayload.is_suspended = true;
                updatePayload.ban_reason = "TEMP_BAN: Double Violent Strike Violations (AI Automated Audit)";
                updatePayload.banned_until = new Date(Date.now() + 24 * 60 * 60 * 1000).toISOString(); // 24-hour Ban
              } 
              // Penalty 2: If twice minor warnings: follow restriction ban for 1 hour
              else if (curWarnings >= 2) {
                updatePayload.follow_restricted_until = new Date(Date.now() + 60 * 60 * 1000).toISOString(); // 1 hour Follow Ban
              }

              await updateDoc(offenderRef, updatePayload);
            }
          }

          showToast("AI Compliance scanning complete. Logging audit report.", "success");
        }, 1500);

