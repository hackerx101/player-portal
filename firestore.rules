rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Protect the core NFSMEC App Data tree
    match /artifacts/nfsmec-bd2f4/public/data {
      
      // Profiles: Anyone authenticated can read or create; only the owner can modify privacy/handles
      match /profiles/{userUid} {
        allow read, create: if request.auth != null;
        allow update: if request.auth != null && request.auth.uid == userUid;
        allow delete: if false; // Profiles shouldn't be deleted casually
      }
      
      // Live Intel Messages: Anyone can read/write, but a user can only delete their OWN transmissions
      match /live_messages/{messageId} {
        allow read, create: if request.auth != null;
        allow delete, update: if request.auth != null && request.auth.uid == resource.data.uid;
      }
      
      // System Flag Reports: Authenticated players can file them; nobody can edit/delete once sent
      match /system_reports/{reportId} {
        allow read: if false; // Keep reports private to your admin panel
        allow create: if request.auth != null;
      }
    }
  }
}
